{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist/server",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": false,
    "noEmit": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/server/**/*",
    "src/shared/**/*",
    "src/sync/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/lib",
    "src/components",
    "src/pages",
    "src/features"
  ]
}
