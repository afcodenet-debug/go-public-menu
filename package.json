    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.106.1",
    "@tanstack/react-query": "^5.100.10",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node-fetch": "^2.6.13",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
