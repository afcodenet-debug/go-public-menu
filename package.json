{
  "name": "great_olive",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "npm run build:main && concurrently \"npm run server\" \"wait-on http://localhost:3001/health && vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:web": "concurrently \"npm run server\" \"wait-on http://localhost:3001/health && vite\"",
    "build": "npm run build:main && npm run build:renderer && npm run build:server",
    "build:renderer": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:vercel": "vite build",
    "build:main": "mkdir -p dist/main && cp src/main/main.js dist/main/ && tsc src/main/preload/preload.ts --outDir dist/main/preload --module commonjs --target es2018 --esModuleInterop --ignoreConfig --skipLibCheck",
    "server": "npm run build:server && node dist/server/server/server.js",
    "build:render": "tsc -p tsconfig.server.json",
    "start:render": "node dist/server/server/server.js",
    "electron": "electron .",
    "dist": "npm run build && electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
